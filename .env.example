# ─── API ────────────────────────────────────────────────────────────────────
# Serveringizning API manzilini ko'rsating.
# Bu qiymat Next.js BUILD vaqtida bundle ichiga yoziladi.
# O'zgarsa — docker compose build mendeleyev_frontend bilan qayta build qiling.
#
# Mahalliy ishlab chiqish:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8180
#
# Server (production):
#   NEXT_PUBLIC_API_BASE_URL=https://api.yoursite.com
#
NEXT_PUBLIC_API_BASE_URL=http://localhost:8180
NEXT_PUBLIC_API_VERSION=v1

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Mendeleyev
NEXT_PUBLIC_DEFAULT_LOCALE=uz

# ─── Auth ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_OTP_LENGTH=6
NEXT_PUBLIC_OTP_COOLDOWN=60

# ─── Feature flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_PWA=false
NEXT_PUBLIC_ENABLE_WEBSOCKET=false
